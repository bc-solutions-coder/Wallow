# Environment
COMPOSE_PROJECT_NAME=foundry-dev
ASPNETCORE_ENVIRONMENT=Development

# App Image
APP_IMAGE=ghcr.io/bc-solutions-coder/foundry
APP_TAG=dev

# PostgreSQL
POSTGRES_USER=foundry
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=foundry

# RabbitMQ
RABBITMQ_USER=foundry
RABBITMQ_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Email (Production only - Dev/Staging use Mailpit)
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
