{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=foundry;Username=OVERRIDE_VIA_ENV_VAR;Password=OVERRIDE_VIA_ENV_VAR"
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "OVERRIDE_VIA_ENV_VAR",
    "Password": "OVERRIDE_VIA_ENV_VAR"
  },
  "Smtp": {
    "Host": "mailpit",
    "Port": 1025,
    "UseSsl": false,
    "DefaultFromAddress": "noreply@foundry.staging",
    "DefaultFromName": "Foundry Staging"
  },
  "Keycloak": {
    "realm": "foundry",
    "auth-server-url": "OVERRIDE_VIA_ENV_VAR",
    "ssl-required": "external",
    "resource": "foundry-api",
    "credentials": {
      "secret": "OVERRIDE_VIA_ENV_VAR"
    },
    "verify-token-audience": true,
    "confidential-port": 0
  },
  "KeycloakAdmin": {
    "realm": "foundry",
    "auth-server-url": "OVERRIDE_VIA_ENV_VAR",
    "resource": "foundry-api",
    "credentials": {
      "secret": "OVERRIDE_VIA_ENV_VAR"
    }
  },
  "Cors": {
    "_corsNote": "AllowedOrigins must be set via environment variables (e.g. Cors__AllowedOrigins__0=https://app.yourdomain.com) before deployment",
    "AllowedOrigins": []
  },
  "Elsa": {
    "Identity": {
      "SigningKey": "OVERRIDE_VIA_ENV_VAR"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "Foundry",
    "OtlpEndpoint": "http://localhost:4318"
  }
}
